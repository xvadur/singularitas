{
  "name": "mail-triage-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local, explicit Gmail triage worker built around gog CLI.",
  "scripts": {
    "triage": "node src/mail-triage/cli.js",
    "triage:dry": "node src/mail-triage/cli.js --config config/mail-triage.sample.json --mailbox business --mode dry-run",
    "triage:apply": "node src/mail-triage/cli.js --config config/mail-triage.sample.json --mailbox business --mode apply"
  }
}
