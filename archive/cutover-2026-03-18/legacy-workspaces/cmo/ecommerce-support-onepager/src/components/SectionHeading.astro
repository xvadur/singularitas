---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  center?: boolean;
}

const { eyebrow, title, intro, center = false } = Astro.props;
---

<div class:list={["section-heading", center && "is-center"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {intro && <p class="intro">{intro}</p>}
</div>
