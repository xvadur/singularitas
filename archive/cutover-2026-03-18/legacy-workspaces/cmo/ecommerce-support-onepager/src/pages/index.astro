---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PackageCard from "../components/PackageCard.astro";
import FaqItem from "../components/FaqItem.astro";

const pains = [
  "Zákazník volá alebo píše s otázkou, ktorú ste už riešili desiatkykrát.",
  "Support stále dookola vysvetľuje kompatibilitu, dopravu, objednávky alebo reklamácie.",
  "Reklamácie sa rozbiehajú cez emaily, PDF formuláre a chýbajúce podklady.",
  "Jednoduché otázky berú čas ľuďom, ktorí majú robiť dôležitejšiu prácu.",
];

const outcomes = ["Pomalé odpovede", "Zbytočný chaos", "Viac ručnej práce", "Horší zákaznícky zážitok"];

const solutionPoints = [
  "Odpovie na opakujúce sa otázky zákazníkov.",
  "Pomôže pri výbere a základnej orientácii.",
  "Vysvetlí ďalší krok pri objednávke, doručení alebo reklamácii.",
  "Vypýta si chýbajúce údaje.",
  "Pripraví prípad pre človeka, keď je to potrebné.",
];

const coverage = [
  {
    title: "Predpredajné otázky",
    items: [
      "Je to skladom?",
      "Kedy to doručíte?",
      "Aký je ďalší krok?",
      "Aké sú možnosti dopravy a platby?",
      "Ako funguje vrátenie alebo reklamácia?",
    ],
  },
  {
    title: "Objednávky a support",
    items: [
      "stav objednávky",
      "základné otázky k doručeniu",
      "navigácia zákazníka na správny ďalší krok",
      "zber údajov pre support tím",
    ],
  },
  {
    title: "Reklamácie a vrátenie",
    items: [
      "vysvetlenie postupu",
      "zber podkladov",
      "čo treba poslať",
      "čo chýba",
      "príprava prípadu pre človeka",
    ],
  },
];

const fit = [
  "výber produktu",
  "kompatibilitu",
  "dostupnosť",
  "stav objednávky",
  "reklamácie",
  "vrátenie tovaru",
];

const verticals = ["autodiely", "pneumatiky", "technické e-shopy", "príslušenstvo", "e-shopy s vyšším support loadom"];

const steps = [
  {
    title: "Zoberieme vaše existujúce podklady",
    items: ["FAQ", "obchodné podmienky", "reklamačný poriadok", "dopravu a platbu", "kontaktné a support informácie"],
  },
  {
    title: "Postavíme support logiku",
    items: [
      "čo môže zodpovedať",
      "čo si má vypýtať",
      "kedy má eskalovať prípad človeku",
      "ako rozdeliť otázky podľa typu",
    ],
  },
  {
    title: "Nasadíme ho na vaše kanály",
    items: ["web chat", "email support", "telefónny front-door", "reklamačný intake"],
  },
  {
    title: "Support tím dostáva menej chaosu",
    items: ["jasne roztriedené požiadavky", "doplnené podklady", "pripravené prípady"],
  },
];

const packages = [
  {
    name: "Support Chat",
    audience: "Pre e-shopy bez chatu.",
    items: ["web chat", "odpovede na FAQ a support otázky", "zber kontaktných údajov", "handoff na človeka"],
    cta: "Chcem začať chatom",
  },
  {
    name: "Support Copilot",
    audience: "Pre e-shopy, kde už support tečie cez web a email.",
    items: ["všetko zo Support Chat", "email triage", "reklamačný intake", "returns guidance", "zber podkladov pre support"],
    cta: "Chcem zjednodušiť support",
    featured: true,
  },
  {
    name: "Full Support Layer",
    audience: "Pre firmy, kde support beží cez viac kanálov a je zbytočne manuálny.",
    items: ["chat", "email support triage", "reklamačný workflow", "returns workflow", "voice/front-door", "knowledge base", "handoff rules"],
    cta: "Chcem kompletnú support vrstvu",
  },
];

const gains = [
  "rýchlejší prvý kontakt so zákazníkom",
  "menej opakujúcich sa otázok pre tím",
  "menej chaosu v supporte",
  "jednoduchší intake reklamácií",
  "menej ručného vysvetľovania",
  "lepšie pripravené prípady pre človeka",
];

const faq = [
  {
    question: "Je to chatbot?",
    answer:
      "Nie v tom lacnom zmysle slova. Je to support agent, ktorý odpovedá z vašich podkladov, zbiera údaje a odovzdáva zložitejšie prípady človeku.",
  },
  {
    question: "Musíme mať všetko integrované?",
    answer:
      "Nie. Na začiatok vieme fungovať aj nad vašimi existujúcimi podkladmi, FAQ a support flowmi. Integrácie sa riešia podľa toho, čo vám naozaj prinesie menej ručnej práce.",
  },
  {
    question: "Vie to riešiť reklamácie?",
    answer:
      "Vie vysvetliť postup, zobrať podklady a pripraviť prípad pre človeka. Pri citlivých alebo nejasných prípadoch ide handoff na tím.",
  },
  {
    question: "Je to vhodné aj pre menší e-shop?",
    answer:
      "Áno, hlavne ak vám support stále padá na jedného človeka alebo riešite veľa opakujúcich sa otázok.",
  },
];

const title = "E-commerce support agent pre support-heavy e-shopy | Xvadur";
const description =
  "AI support vrstva pre autodiely, pneumatiky a technické e-shopy. Menej rutiny, rýchlejšie odpovede a pripravené prípady pre človeka.";
---

<MainLayout title={title} description={description}>
  <header class="topbar">
    <div class="container topbar-inner">
      <a class="brand" href="#hero">
        <span class="brand-mark">X</span>
        <span>
          <strong>Xvadur</strong>
          <small>E-commerce support agent</small>
        </span>
      </a>

      <nav class="nav">
        <a href="#riesenie">Riešenie</a>
        <a href="#baliky">Balíčky</a>
        <a href="#faq">FAQ</a>
        <a class="nav-cta" href="#kontakt">Chcem ukážku</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero" id="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Pre support-heavy e-shopy</p>
          <h1>Customer support, ktorý odpovie skôr, než zákazník odíde</h1>
          <p class="hero-lead">
            Pre e-shopy, kde sa stále opakujú tie isté otázky — výber produktu, dostupnosť, stav objednávky,
            reklamácie a vrátenie tovaru.
          </p>
          <p class="hero-subcopy">
            Nasadíme vám AI support vrstvu, ktorá odchytí rutinu cez chat, email alebo telefón a človeku posunie
            už pripravený prípad. Nie ďalší inbox. Nie ďalší chaos. Praktická front-door vrstva pre support, ktorý
            už teraz nestíha.
          </p>

          <div class="hero-actions">
            <a class="button primary" href="#kontakt">Chcem ukážku pre svoj e-shop</a>
            <a class="button secondary" href="#ako-to-funguje">Pozrieť, ako to funguje</a>
          </div>

          <ul class="hero-tags">
            <li>Autodiely</li>
            <li>Pneumatiky</li>
            <li>Technické e-shopy</li>
            <li>Vyšší support load</li>
          </ul>
        </div>

        <aside class="hero-panel">
          <div class="signal-card">
            <p class="signal-title">Čo to znamená v praxi</p>
            <ul>
              <li>Zákazník dostane odpoveď hneď na webe, v emaile alebo na telefóne.</li>
              <li>Support tím už nedostáva neúplné správy bez kontextu.</li>
              <li>Zložité prípady idú človeku až vtedy, keď už majú podklady.</li>
            </ul>
          </div>

          <div class="channel-flow">
            <div>
              <span class="flow-label">Kanály</span>
              <strong>Chat · Email · Telefón</strong>
            </div>
            <div class="flow-arrow">→</div>
            <div>
              <span class="flow-label">Support agent</span>
              <strong>Rutina + intake</strong>
            </div>
            <div class="flow-arrow">→</div>
            <div>
              <span class="flow-label">Človek</span>
              <strong>Hotový prípad</strong>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="section muted-section" id="problem">
      <div class="container">
        <SectionHeading
          eyebrow="Problém"
          title="Keď support visí na ľuďoch, všetko sa spomaľuje"
          intro="Väčšina e-shopov stále rieši customer support ručne. Keď sa opakujú tie isté otázky, prestáva to byť support a začína to byť brzda prevádzky."
        />

        <div class="problem-grid">
          <div class="card">
            <ul class="check-list">
              {pains.map((pain) => <li>{pain}</li>)}
            </ul>
          </div>
          <div class="card dark-card">
            <p class="card-kicker">Výsledok</p>
            <div class="result-strip">
              {outcomes.map((item) => <span>{item}</span>)}
            </div>
            <p>
              Ak predpredajné otázky, stavy objednávok a reklamácie padajú stále na tých istých ľudí, odpovede sa
              predlžujú a dôležitejšie prípady čakajú. Presne tam vzniká priestor pre support vrstvu, ktorá nerieši
              všetko, ale odchytí rutinu skôr, než zoberie deň celému tímu.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="riesenie">
      <div class="container">
        <SectionHeading
          eyebrow="Riešenie"
          title="Presne na toto je náš e-commerce support agent"
          intro="Namiesto ďalšieho človeka dostanete support vrstvu, ktorá filtruje rutinu, zbiera údaje a posúva len to, čo už má zmysel riešiť manuálne."
        />

        <div class="solution-grid">
          <div class="card">
            <ul class="check-list">
              {solutionPoints.map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <div class="callout-card">
            <p class="callout-kicker">Bez AI hmly</p>
            <h3>Nie je to „AI pre všetko“.</h3>
            <p>
              Je to praktický support agent pre rutinné otázky a support intake. Pre operátora to znamená menej
              copy-paste odpovedí. Pre zákazníka to znamená rýchlejší prvý kontakt. Pre majiteľa e-shopu to znamená,
              že support nemusí rásť lineárne s počtom ticketov.
            </p>
            <a class="text-link" href="#kontakt">Ukážte mi, ako by to fungovalo u nás</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section muted-section" id="pokrytie">
      <div class="container">
        <SectionHeading
          eyebrow="Pokrytie"
          title="Čo agent vybaví za vás"
          intro="Od opakujúcich sa predpredajných otázok až po intake reklamácií. Agent nič nehádá — pýta sa, smeruje a keď treba, eskaluje človeku."
        />

        <div class="coverage-grid">
          {coverage.map((group) => (
            <article class="card coverage-card">
              <h3>{group.title}</h3>
              <ul class="bullet-list">
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
          <article class="card handoff-card">
            <p class="card-kicker">Handoff človeku</p>
            <h3>Keď ide o zložitejší prípad, agent nič nehádá.</h3>
            <p>
              Zoberie potrebné údaje a posunie ho ďalej človeku už v pripravenej forme. Tím tak nerieši začiatok,
              ale priamo podstatu problému.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="pre-koho">
      <div class="container two-col-fit">
        <div>
          <SectionHeading
            eyebrow="Pre koho"
            title="Najväčší zmysel to dáva pre e-shopy, kde zákazníci často riešia"
          />
          <div class="chip-grid">
            {fit.map((item) => <span>{item}</span>)}
          </div>
        </div>
        <div class="card fit-card">
          <p class="card-kicker">Typicky</p>
          <ul class="bullet-list compact">
            {verticals.map((item) => <li>{item}</li>)}
          </ul>
          <p>
            Najlepšie funguje tam, kde je produktový výber technickejší, zákazník potrebuje uistenie pred nákupom a
            support už dnes trávi veľa času vysvetľovaním rovnakých vecí dookola.
          </p>
        </div>
      </div>
    </section>

    <section class="section muted-section" id="ako-to-funguje">
      <div class="container">
        <SectionHeading
          eyebrow="Nasadenie"
          title="Ako to nasadíme"
          intro="Bez zbytočne technického procesu. Zoberieme to, čo už máte, nastavíme rozhodovaciu logiku a pustíme support vrstvu tam, kde dnes vzniká najväčší tlak."
        />

        <div class="steps-grid">
          {steps.map((step, index) => (
            <article class="step-card">
              <div class="step-index">0{index + 1}</div>
              <h3>{step.title}</h3>
              <ul class="bullet-list compact">
                {step.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="baliky">
      <div class="container">
        <SectionHeading
          eyebrow="Balíčky"
          title="3 spôsoby, ako to nasadiť"
          intro="Môžete začať malým support chatom alebo postaviť kompletnú support vrstvu cez viac kanálov. Dôležité je, aby balík sedel na reálny support load, nie na módne AI názvy."
          center={true}
        />
        <div class="packages-grid">
          {packages.map((pkg) => <PackageCard {...pkg} />)}
        </div>
      </div>
    </section>

    <section class="section muted-section" id="benefity">
      <div class="container two-col-fit">
        <div>
          <SectionHeading eyebrow="Prečo to funguje" title="Čo tým získate" />
          <ul class="check-list gains-list">
            {gains.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="card dark-card no-promise-card">
          <p class="card-kicker">Bez bullshitu</p>
          <h3>Čo nesľubujeme</h3>
          <p>Nesľubujeme, že AI nahradí celý support tím.</p>
          <ul class="bullet-list compact">
            <li>odchytíme rutinu</li>
            <li>zoberieme podklady</li>
            <li>zrýchlime prvý kontakt</li>
            <li>pripravíme prípad pre človeka</li>
          </ul>
          <p>To je reálna hodnota, ktorú zákazník aj tím pocítia.</p>
        </div>
      </div>
    </section>

    <section class="section cta-section" id="kontakt">
      <div class="container cta-box">
        <div>
          <p class="eyebrow">Ukážka na mieru</p>
          <h2>Chcete vidieť, ako by to fungovalo na vašom e-shope?</h2>
          <p>
            Pošleme vám krátku ukážku priamo na váš web: čo by agent vedel vybaviť, kde by znížil support load a
            ktorý balík vám dáva najväčší zmysel.
          </p>
        </div>
        <div class="cta-side">
          <ul class="bullet-list compact">
            <li>krátky audit opakujúcich sa otázok</li>
            <li>návrh najvhodnejšieho vstupného balíka</li>
            <li>konkrétne use-casy pre autodiely, pneumatiky a technický sortiment</li>
          </ul>
          <a class="button primary wide" href="mailto:adam@xvadur.com?subject=Uk%C3%A1%C5%BEka%20pre%20m%C3%B4j%20e-shop">
            Pošlite mi ukážku pre môj e-shop
          </a>
        </div>
      </div>
    </section>

    <section class="section faq-section" id="faq">
      <div class="container faq-grid">
        <div>
          <SectionHeading
            eyebrow="FAQ"
            title="Časté otázky"
            intro="Otázky, ktoré typicky padnú skôr, než si e-shop povie o konkrétnu ukážku."
          />
        </div>
        <div class="faq-list">
          {faq.map((item) => <FaqItem {...item} />)}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p>
        AI support vrstva pre e-shopy, ktorá vybaví opakujúce sa otázky, zoberie podklady k reklamácii a človeku
        posunie už pripravený prípad.
      </p>
      <a href="mailto:adam@xvadur.com">adam@xvadur.com</a>
    </div>
  </footer>
</MainLayout>
