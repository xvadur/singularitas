---
interface Props {
  name: string;
  audience: string;
  items: string[];
  cta: string;
  featured?: boolean;
}

const { name, audience, items, cta, featured = false } = Astro.props;
---

<article class:list={["package-card", featured && "is-featured"]}>
  <div class="package-top">
    <p class="package-label">Balík</p>
    <h3>{name}</h3>
    <p class="package-audience">{audience}</p>
  </div>
  <ul>
    {items.map((item) => <li>{item}</li>)}
  </ul>
  <a class="mini-link" href="#kontakt">{cta}</a>
</article>
